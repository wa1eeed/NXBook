# ============================================================
# NXBook — environment variables (documented template)
# Copy to .env.development / .env.staging / .env.production and
# fill real values. Local dev ships safe defaults; only the
# third-party API keys need real credentials to unlock features.
# ============================================================

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost          # used for subdomain tenant routing
PORT=3000
# Public IP the dashboard shows tenants for their custom-domain A record.
PLATFORM_SERVER_IP=

# ── Database (Postgres) ─────────────────────────────────────
# NOTE: local docker maps Postgres to host port 5433 (5432 may be taken).
DATABASE_URL=postgresql://platform:devpassword@localhost:5433/nxbook_dev
DB_USER=platform
DB_PASSWORD=devpassword
DB_NAME=nxbook_dev

# ── Redis (cache + BullMQ) ──────────────────────────────────
# NOTE: local docker maps Redis to host port 6380 (6379 may be taken).
REDIS_URL=redis://:devredis@localhost:6380
REDIS_PASSWORD=devredis

# ── Auth / crypto ───────────────────────────────────────────
# Generate fresh per environment: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-32-bytes-base64
NEXTAUTH_URL=http://localhost:3000
# Exactly 32 chars = AES-256 key for encrypting tenant AI keys at rest.
JWT_ENCRYPTION_KEY=change-me-exactly-32-characters!!

# ── AI providers (agents fall back to templates without these) ──
ANTHROPIC_API_KEY=TODO_PASTE            # console.anthropic.com
OPENAI_API_KEY=TODO_PASTE               # platform.openai.com/api-keys
DEFAULT_AI_PROVIDER=anthropic
DEFAULT_MODEL_FAST=claude-haiku-4-5
DEFAULT_MODEL_SMART=claude-sonnet-4-6
DEFAULT_MODEL_FALLBACK=gpt-4o-mini

# ── File storage: Cloudflare R2 (S3-compatible) ─────────────
# To move to AWS S3: drop R2_ACCOUNT_ID, set AWS_REGION.
R2_ACCOUNT_ID=TODO_PASTE
R2_ACCESS_KEY_ID=TODO_PASTE
R2_SECRET_ACCESS_KEY=TODO_PASTE
R2_BUCKET_NAME=nxbook-files-dev
R2_PUBLIC_URL=https://dev-files.nxbook.app

# ── Payments: Moyasar (use test keys in dev) ────────────────
MOYASAR_SECRET_KEY=TODO_PASTE
MOYASAR_PUBLISHABLE_KEY=TODO_PASTE
MOYASAR_WEBHOOK_SECRET=TODO_PASTE       # used to verify inbound webhook signatures

# ── SMS + WhatsApp: Twilio ──────────────────────────────────
TWILIO_ACCOUNT_SID=TODO_PASTE           # starts with AC
TWILIO_AUTH_TOKEN=TODO_PASTE
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio WhatsApp sandbox by default
TWILIO_SMS_FROM=TODO_PASTE              # your Twilio number (+E.164)

# ── Email: Resend ───────────────────────────────────────────
RESEND_API_KEY=TODO_PASTE
EMAIL_FROM=dev@nxbook.app
EMAIL_REPLY_TO=support@nxbook.app

# ── Error monitoring: Sentry (no-ops while DSN is a TODO) ───
SENTRY_DSN=TODO_PASTE
NEXT_PUBLIC_SENTRY_DSN=TODO_PASTE
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Only for CI source-map upload — leave blank locally.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Feature flags ───────────────────────────────────────────
ENABLE_AI_AGENTS=true
ENABLE_CREDIT_TOPUP=true
ENABLE_CUSTOM_AGENTS=false
ENABLE_WAITLIST=true
SUPER_ADMIN_EMAIL=admin@nxbook.app
# Password used by prisma/seed.ts for the initial super-admin account.
# CHANGE THIS before running seed in production, then change it again after first login.
SUPER_ADMIN_PASSWORD=CHANGE_ME_BEFORE_SEEDING

# ── Payment encryption ──────────────────────────────────────
# Per-tenant gateway API keys are stored encrypted with this key.
# Generate: openssl rand -hex 32
# REQUIRED if any tenant connects a payment gateway.
ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_-hex_32

# ── NXBook Pay (platform-level Moyasar account) ─────────────
# Used when a tenant chooses "NXBook Pay" instead of their own gateway.
NXBOOK_PAY_SECRET_KEY=TODO_PASTE
NXBOOK_PAY_PUBLIC_KEY=TODO_PASTE
