# ─── Git & CI ───────────────────────────────────────────────
.git
.gitignore
.github

# ─── Dependencies (installed inside Docker) ─────────────────
node_modules

# ─── Build output (re-created inside Docker) ────────────────
.next

# ─── Local env files (secrets — NEVER bake into image) ──────
.env
.env.*
!.env.example

# ─── Dev / test tooling ─────────────────────────────────────
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__
coverage
.jest*

# ─── Editor / OS noise ──────────────────────────────────────
.DS_Store
*.swp
*.swo
.vscode
.idea

# ─── Documentation (not needed in the image) ────────────────
docs
README.md
CHANGELOG.md
CONTRIBUTING.md
